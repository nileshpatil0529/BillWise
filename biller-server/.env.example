# BillWise Server Configuration - SQLite Edition
# Copy this to .env and adjust values

# Server
PORT=3000
NODE_ENV=development

# JWT Configuration (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=24h

# Default Admin Credentials (CHANGE IN PRODUCTION!)
ADMIN_EMAIL=admin@biller.com
ADMIN_PASSWORD=Admin@123

# CORS (Adjust for your frontend URL)
CORS_ORIGIN=http://localhost:4200

# Thermal Printer Configuration
# Network Printer: tcp://192.168.1.100:9100
# Windows Serial: \\\\.\\COM3
# Linux USB: /dev/usb/lp0
# Mac USB: /dev/cu.usbserial
PRINTER_INTERFACE=tcp://localhost:9100
