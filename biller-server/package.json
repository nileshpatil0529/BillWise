{
  "name": "biller-server",
  "version": "2.0.0",
  "description": "Backend server for Biller Application - SQLite Edition",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "cd ../biller-app && npm run build",
    "build:prod": "cd ../biller-app && npx ng build --configuration=production",
    "serve": "npm run build:prod && node src/app.js",
    "backup": "node src/scripts/backup.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
